<% layout('boilerplate') %>
<% pageTitle = listing.title + ' | WanderLust' %>
<% pageStyle = 'show.css' %>

<!-- Main property detail layout -->
  <main class="show-wrap">
    <!-- Property heading/meta -->
    <section class="property-head">
      <p class="eyebrow">Entire place in <%= listing.location %></p>
      <h1><%= listing.title %></h1>
      <p class="meta"><%= listing.location %>, <%= listing.country %></p>
    </section>

    <!-- Gallery section: one hero image + thumbnail grid -->
    <section class="gallery-grid">
      <div class="hero-image">
        <!-- Use first image as main hero image -->
        <img src="<%= listing.images && listing.images.length ? listing.images[0] : 'https://images.unsplash.com/photo-1448630360428-65456885c650?q=80&w=1167&auto=format&fit=crop' %>" alt="<%= listing.title %>" />
      </div>

      <div class="thumb-col">
        <!-- If more images exist, show up to 4 thumbnails -->
        <% if (listing.images && listing.images.length > 1) { %>
          <% listing.images.slice(1, 5).forEach((img) => { %>
            <img src="<%= img %>" alt="<%= listing.title %>" />
          <% }) %>
        <% } else { %>
          <!-- If only one image exists, repeat it to keep layout balanced -->
          <img src="<%= listing.images && listing.images.length ? listing.images[0] : 'https://images.unsplash.com/photo-1448630360428-65456885c650?q=80&w=1167&auto=format&fit=crop' %>" alt="<%= listing.title %>" />
          <img src="<%= listing.images && listing.images.length ? listing.images[0] : 'https://images.unsplash.com/photo-1448630360428-65456885c650?q=80&w=1167&auto=format&fit=crop' %>" alt="<%= listing.title %>" />
          <img src="<%= listing.images && listing.images.length ? listing.images[0] : 'https://images.unsplash.com/photo-1448630360428-65456885c650?q=80&w=1167&auto=format&fit=crop' %>" alt="<%= listing.title %>" />
          <img src="<%= listing.images && listing.images.length ? listing.images[0] : 'https://images.unsplash.com/photo-1448630360428-65456885c650?q=80&w=1167&auto=format&fit=crop' %>" alt="<%= listing.title %>" />
        <% } %>
      </div>
    </section>

    <!-- Two-column content: description + booking card -->
    <section class="property-content">
      <article class="details-card">
        <h2>About this place</h2>
        <p><%= listing.description %></p>
      </article>

      <!-- Right panel with price and booking CTA -->
      <aside class="booking-card">
        <p class="price">₹ <%= Number(listing.price).toLocaleString('en-IN') %> <span>/ night</span></p>
        <button type="button">Reserve</button>
        <p class="note">You won't be charged yet</p>
        <ul>
          <li>Free cancellation for 48 hours</li>
          <li>Instant host support</li>
          <li>Trusted WanderLust stay</li>
        </ul>
      </aside>
    </section>

    <!-- Review form section -->
    <section class="review-form-section">
      <h2>Leave a Review</h2>
      <form action="/listings/<%= listing._id %>/reviews" method="POST" class="review-form">
        <div class="form-group">
          <label>Rating</label>
          <!-- Star rating: DOM order 5→1 + flex row-reverse = visual order 1→5 -->
          <div class="star-rating">
            <input type="radio" id="star5" name="review[rating]" value="5" required>
            <label for="star5" title="5 – Excellent">★</label>
            <input type="radio" id="star4" name="review[rating]" value="4">
            <label for="star4" title="4 – Very Good">★</label>
            <input type="radio" id="star3" name="review[rating]" value="3">
            <label for="star3" title="3 – Good">★</label>
            <input type="radio" id="star2" name="review[rating]" value="2">
            <label for="star2" title="2 – Fair">★</label>
            <input type="radio" id="star1" name="review[rating]" value="1">
            <label for="star1" title="1 – Poor">★</label>
          </div>
        </div>
        <div class="form-group">
          <label for="comment">Comment</label>
          <textarea name="review[comment]" id="comment" rows="4" placeholder="Share your experience..." required></textarea>
        </div>
        <button type="submit" class="submit-review-btn">Submit Review</button>
      </form>
    </section>

    <!-- Submitted reviews display -->
    <% if (listing.reviews && listing.reviews.length > 0) { %>
    <section class="reviews-section">
      <h2>Reviews (<%= listing.reviews.length %>)</h2>
      <div class="reviews-grid">
        <% listing.reviews.forEach(review => { %>
        <div class="review-card">
          <div class="review-stars">
            <% for (let i = 1; i <= 5; i++) { %>
              <span class="star<%= i <= review.rating ? ' filled' : '' %>">★</span>
            <% } %>
            <span class="review-rating-num"><%= review.rating %>/5</span>
          </div>
          <p class="review-comment"><%= review.comment %></p>
          <p class="review-date"><%= review.createdAt.toLocaleDateString('en-IN', { year: 'numeric', month: 'long', day: 'numeric' }) %></p>
          <form class="review-delete-form" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE" method="POST">
            <button type="submit" class="review-delete-btn">Delete review</button>
          </form>
        </div>
        <% }) %>
      </div>
    </section>
    <% } %>

    <!-- Delete section at bottom -->
    <section class="delete-section">
      <form class="delete-form" action="/listings/<%= listing._id %>?_method=DELETE" method="POST">
        <input type="hidden" name="_method" value="DELETE" />
        <button class="delete-btn" type="submit">Delete Property</button>
      </form>
    </section>
  </main>
