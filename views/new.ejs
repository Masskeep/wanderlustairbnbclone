<% layout('boilerplate') %>
<% pageTitle = 'Create Listing | WanderLust' %>
<% pageStyle = 'listings.css' %>

<!-- Intro section for the create page -->
  <section class="hero">
    <h1>Create New Listing</h1>
    <p>Add a new property to your WanderLust portfolio.</p>
    <span class="count-pill">Host dashboard</span>
  </section>

  <!-- Form container -->
  <main class="grid-wrap">
    <section class="form-shell">
      <!-- Form submits to POST /listings -->
      <form class="listing-form" action="/listings" method="POST">
        <div class="form-row">
          <label for="title">Title</label>
          <!-- Name uses listing[...] so Express receives req.body.listing -->
          <input id="title" name="listing[title]" type="text" placeholder="Cozy Lakefront Cabin" required />
        </div>

        <div class="form-row">
          <label for="description">Description</label>
          <textarea id="description" name="listing[description]" rows="5" placeholder="Tell guests what makes this place special..." required></textarea>
        </div>

        <div class="form-row split">
          <div>
            <label for="image">Image Link</label>
            <!-- You can paste one URL or comma-separated URLs -->
            <input id="image" name="listing[images]" type="url" placeholder="https://images.unsplash.com/..." required />
          </div>
          <div>
            <label for="price">Price (per night)</label>
            <input id="price" name="listing[price]" type="number" min="1" placeholder="4500" required />
          </div>
        </div>

        <div class="form-row split">
          <div>
            <label for="location">Location / City</label>
            <input id="location" name="listing[location]" type="text" placeholder="Manali" required />
          </div>
          <div>
            <label for="country">Country Name</label>
            <input id="country" name="listing[country]" type="text" placeholder="India" required />
          </div>
        </div>

        <!-- Final submit action -->
        <button class="submit-btn" type="submit">Create Listing</button>
      </form>
    </section>
  </main>
